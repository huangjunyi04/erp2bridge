          "groupAllowFrom": { "type": "array", "items": { "type": "string" }, "description": "UIDs allowed to send messages in group contexts" },
          "pingIntervalMs": { "type": "integer", "minimum": 1000, "description": "WebSocket ping interval in milliseconds (default: 30000)" },
          "reconnectBaseMs": { "type": "integer", "minimum": 100, "description": "Base reconnect delay in milliseconds (default: 1000)" },
          "reconnectMaxMs": { "type": "integer", "minimum": 1000, "description": "Maximum reconnect delay in milliseconds (default: 30000)" },
          "connectTimeoutMs": { "type": "integer", "minimum": 1000, "description": "WebSocket connection timeout in milliseconds (default: 10000)" },
          "defaultAccount": { "type": "string", "description": "Default account ID to use when accountId is not specified" },
          "groups": {
