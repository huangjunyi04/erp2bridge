        "tokenFile": { "label": "Token File Path", "help": "Path to a file containing the bearer token (takes priority over token)" },
        "dmPolicy": { "label": "DM Policy", "help": "Controls who can send direct messages. 'pairing' = approval required, 'open' = anyone, 'allowlist' = uid must be in allowFrom list" },
        "allowFrom": { "label": "Allowed UIDs (DM)", "help": "List of UIDs that are allowed to send DMs" },
        "groups.*.requireMention": { "label": "Require Mention", "help": "If true, the bot must be @mentioned in group messages for it to respond" }
      }
    }
  }
}